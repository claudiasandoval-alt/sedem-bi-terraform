{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-sedembi-prod-001"
		},
		"LS_DataLake_SEDEM_accountKey": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"accountKey\"de \"LS_DataLake_SEDEM\""
		},
		"LS_SQLDatabase_DWH_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"LS_SQLDatabase_DWH\""
		},
		"LS_DataLake_SEDEM_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stsedembiprod001.dfs.core.windows.net/"
		},
		"LS_SQLDatabase_DWH_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-sedembi-prod-001.database.windows.net"
		},
		"LS_SQLDatabase_DWH_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-sedembi-dwh-prod"
		},
		"LS_SQLDatabase_DWH_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "admin_sedem"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/LS_DataLake_SEDEM')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('LS_DataLake_SEDEM_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('LS_DataLake_SEDEM_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/LS_SQLDatabase_DWH')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('LS_SQLDatabase_DWH_properties_typeProperties_server')]",
					"database": "[parameters('LS_SQLDatabase_DWH_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('LS_SQLDatabase_DWH_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('LS_SQLDatabase_DWH_password')]"
					}
				}
			},
			"dependsOn": []
		},
