{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "adf-sedembi-prod-001"
		},
		"LS_DataLake_SEDEM_accountKey": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"accountKey\"de \"LS_DataLake_SEDEM\""
		},
		"LS_SQLDatabase_DWH_password": {
			"type": "secureString",
			"metadata": "Cadena protegida para \"password\"de \"LS_SQLDatabase_DWH\""
		},
		"LS_DataLake_SEDEM_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stsedembiprod001.dfs.core.windows.net/"
		},
		"LS_SQLDatabase_DWH_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-sedembi-prod-001.database.windows.net"
		},
		"LS_SQLDatabase_DWH_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-sedembi-dwh-prod"
		},
		"LS_SQLDatabase_DWH_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "admin_sedem"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI de la cuenta de almacenamiento que contiene las plantillas de ARM vinculadas."
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Token de SAS para la cuenta de almacenamiento que contiene las plantillas de ARM vinculadas"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-sedembi-prod-001_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_DataLake_SEDEM_accountKey": {
						"value": "[parameters('LS_DataLake_SEDEM_accountKey')]"
					},
					"LS_SQLDatabase_DWH_password": {
						"value": "[parameters('LS_SQLDatabase_DWH_password')]"
					},
					"LS_DataLake_SEDEM_properties_typeProperties_url": {
						"value": "[parameters('LS_DataLake_SEDEM_properties_typeProperties_url')]"
					},
					"LS_SQLDatabase_DWH_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLDatabase_DWH_properties_typeProperties_server')]"
					},
					"LS_SQLDatabase_DWH_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLDatabase_DWH_properties_typeProperties_database')]"
					},
					"LS_SQLDatabase_DWH_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLDatabase_DWH_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}