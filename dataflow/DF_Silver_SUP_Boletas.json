{
	"name": "DF_Silver_SUP_Boletas",
	"properties": {
		"folder": {
			"name": "Bronze/SUP"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_SUP_Boletas_csv",
						"type": "DatasetReference"
					},
					"name": "boletas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_Parquet_SUP_Boletas",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> boletas",
				"boletas derive(fecha_emision = iif(isNull(byName('fecha_emision')) || trim(toString(byName('fecha_emision'))) == '', toDate(null()), coalesce(toDate(trim(toString(byName('fecha_emision'))), 'yyyy-MM-dd'), toDate(trim(toString(byName('fecha_emision'))), 'dd-MM-yyyy'), toDate(trim(toString(byName('fecha_emision'))), 'dd/MM/yyyy'))),",
				"          ci_beneficiaria = iif(isNull(byName('ci_beneficiaria')) || trim(toString(byName('ci_beneficiaria'))) == '', 'SIN_CI', upper(regexReplace(trim(toString(byName('ci_beneficiaria'))), '[^a-zA-Z0-9]', ''))),",
				"          estado = iif(isNull(byName('estado')) || trim(toString(byName('estado'))) == '', 'Sin Estado', initCap(lower(trim(toString(byName('estado')))))),",
				"          nro_boleta = upper(trim(toString(byName('nro_boleta'))))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          boleta_id as string,",
				"          control_id as string,",
				"          ci_beneficiaria as string,",
				"          nro_boleta as string,",
				"          fecha_emision as string,",
				"          estado as string",
				"     ),",
				"     partitionFileNames:['sup_boletas.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}