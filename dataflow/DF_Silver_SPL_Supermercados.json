{
	"name": "DF_Silver_SPL_Supermercados",
	"properties": {
		"folder": {
			"name": "Bronze/SPL"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_SPL_Supermercados_csv",
						"type": "DatasetReference"
					},
					"name": "supermerc"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_Parquet_SPL_Supermercado",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ID as string,",
				"          Cadena as string,",
				"          Sucursal as string,",
				"          Municipio as string,",
				"          {Dirección} as string,",
				"          Estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> supermerc",
				"supermerc derive(ID =      toInteger(trim(toString(ID))),",
				"          Cadena = trim(toString(Cadena)),",
				"          Sucursal = trim(toString(Sucursal)),",
				"          Municipio =      trim(toString(Municipio)),",
				"          Estado = initCap(lower(trim(toString(Estado))))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['spl_supermercados.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}