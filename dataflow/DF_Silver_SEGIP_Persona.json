{
	"name": "DF_Silver_SEGIP_Persona",
	"properties": {
		"folder": {
			"name": "Bronze/SEGIP"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_SEGIP",
						"type": "DatasetReference"
					},
					"name": "OrigenSegipPersonas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_Parquet_SEGIP",
						"type": "DatasetReference"
					},
					"name": "DestinoSilverSegip"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ci as string,",
				"          nombres as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          fecha_nacimiento as date,",
				"          genero as string,",
				"          estado_civil as string,",
				"          ci_conyuge as string,",
				"          numero_hijos as short,",
				"          ci_padre as string,",
				"          ci_madre as string,",
				"          profesion as string,",
				"          nivel_estudios as string,",
				"          municipio_residencia as string,",
				"          fecha_emision as date",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> OrigenSegipPersonas",
				"OrigenSegipPersonas derive(nombres = trim(nombres),",
				"          apellido_paterno = trim(apellido_paterno),",
				"          apellido_materno = trim(apellido_materno)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['segip_personas.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> DestinoSilverSegip"
			]
		}
	}
}