{
	"name": "DF_Silver_SPL_Certificados_Medicos",
	"properties": {
		"folder": {
			"name": "Bronze/SPL"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Bronze_SPL_Certificados_Medicos_csv",
						"type": "DatasetReference"
					},
					"name": "cerMedicos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Silver_Parquet_SPL_Certificados_Medicos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          certificado_id as string,",
				"          afiliacion_id as string,",
				"          fecha_emision as string,",
				"          semana_gestacion as string,",
				"          fecha_probable_parto as string,",
				"          medico_responsable as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> cerMedicos",
				"cerMedicos derive(certificado_id = toInteger(certificado_id),",
				"          fecha_probable_parto = iif(     isNull(fecha_probable_parto) || trim(toString(fecha_probable_parto))=='',     toDate('1900-01-01'),     toDate(toString(fecha_probable_parto),'yyyy-MM-dd') ),",
				"          semana_gestacion = toInteger(     iif(         isNull(semana_gestacion) || trim(toString(semana_gestacion))=='',         '0',         toString(semana_gestacion)     ) ),",
				"          fecha_emision = toDate(toString(fecha_emision),'yyyy-MM-dd'),",
				"          estado = iif( isNull(estado) || trim(toString(estado))=='', 'Sin Estado', initCap(lower(trim(toString(estado)))) ),",
				"          medico_responsable = trim(toString(medico_responsable))) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['spl_certificados_medicos.parquet'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}