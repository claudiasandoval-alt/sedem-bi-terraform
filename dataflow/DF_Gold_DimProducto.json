{
	"name": "DF_Gold_DimProducto",
	"properties": {
		"folder": {
			"name": "Gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Silver_Parquet_SUP_Catalogo_Paquetes",
						"type": "DatasetReference"
					},
					"name": "OrigenSilverProductos"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_Gold_DimProducto",
						"type": "DatasetReference"
					},
					"name": "DestinoGoldDimProducto"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          paquete_id as short,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as double,",
				"          costo_estimado_bs as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> OrigenSilverProductos",
				"OrigenSilverProductos derive(Categoria = 'Paquete de Subsidio',",
				"          Proveedor = 'SEDEM') ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          IdProducto = paquete_id,",
				"          NombrePaquete = nombre,",
				"          Categoria,",
				"          Proveedor",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ProductoKey as integer,",
				"          IdProducto as integer,",
				"          NombrePaquete as string,",
				"          Categoria as string,",
				"          Proveedor as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> DestinoGoldDimProducto"
			]
		}
	}
}