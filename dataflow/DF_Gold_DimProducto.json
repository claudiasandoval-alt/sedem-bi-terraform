{
	"name": "DF_Gold_DimProducto",
	"properties": {
		"folder": {
			"name": "Gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_Silver_Parquet_SUP_Catalogo_Paquetes",
						"type": "DatasetReference"
					},
					"name": "OrigenSilverProductos"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          paquete_id as short,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as double,",
				"          costo_estimado_bs as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> OrigenSilverProductos",
				"OrigenSilverProductos derive(Categoria = 'Paquete de Subsidio',",
				"          Proveedor = 'SEDEM') ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          ci,",
				"          nombres,",
				"          apellido_paterno,",
				"          apellido_materno,",
				"          fecha_nacimiento,",
				"          genero,",
				"          estado_civil,",
				"          ci_conyuge,",
				"          numero_hijos,",
				"          ci_padre,",
				"          ci_madre,",
				"          profesion,",
				"          nivel_estudios,",
				"          municipio_residencia,",
				"          fecha_emision,",
				"          Categoria,",
				"          Proveedor",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1"
			]
		}
	}
}